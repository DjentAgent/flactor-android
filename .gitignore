########################################
# Android / Kotlin / Gradle
########################################

# Gradle Wrapper & Cache
.gradle/
gradle-wrapper.jar
gradle-wrapper.properties

# Project-wide build outputs
/build/
/**/build/

# Module‑specific build outputs
/app/build/
/app/.gradle/

# Local config (SDK path, keystores)
local.properties
keystore.properties
keystore.properties.*
!keystore.properties.example

# Keystore files (if вы храните подписи в проекте)
*.jks
*.keystore

########################################
# IDE
########################################

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# VSCode
.vscode/

########################################
# Kotlin/Java artifacts
########################################

# Java class files
*.class

# Kotlin metadata
*.kotlin_module

# Generated by Dagger/Hilt, DataBinding, ViewBinding
**/build/generated/

########################################
# Miscellaneous
########################################

# Log files
*.log

# Captured screenshots, heap dumps, etc.
captures/

# ProGuard folder (if Eclipse)
proguard/

# OS‑specific
.DS_Store
Thumbs.db
REFACTOR_PROGRESS.md
UX_IMPROVEMENTS.md
